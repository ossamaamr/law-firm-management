# ========================================\n# CasEngine - نظام إدارة مكتب المحاماة\n# Environment Variables Configuration\n# ========================================\n\n# ========================================\n# Database Configuration\n# إعدادات قاعدة البيانات\n# ========================================\nDATABASE_URL=\"postgresql://user:password@localhost:5432/law_firm\"\n\n# ========================================\n# Authentication Configuration\n# إعدادات المصادقة\n# ========================================\nJWT_SECRET=\"your-super-secret-jwt-key-here-change-in-production\"\nJWT_EXPIRATION=\"7d\"\n\n# ========================================\n# Email Configuration\n# إعدادات البريد الإلكتروني\n# ========================================\nSMTP_HOST=\"smtp.gmail.com\"\nSMTP_PORT=\"587\"\nSMTP_SECURE=\"false\"\nSMTP_USER=\"boss1291boss@gmail.com\"\nSMTP_PASSWORD=\"your-app-password-here\"\nSMTP_FROM=\"boss1291boss@gmail.com\"\n\n# Contact Emails\nVITE_SUPPORT_EMAIL=\"boss1291boss@gmail.com\"\nVITE_NOTIFICATION_EMAIL=\"boss1291boss@gmail.com\"\nVITE_REPORTS_EMAIL=\"boss1291boss@gmail.com\"\nVITE_CONTACT_EMAIL=\"boss1291boss@gmail.com\"\nVITE_CONTACT_PHONE=\"+966\"\nVITE_CONTACT_ADDRESS=\"المملكة العربية السعودية\"\nVITE_WEBSITE_URL=\"https://casengine.com\"\n\n# ========================================\n# Payment Gateway Configuration\n# إعدادات بوابات الدفع\n# ========================================\n# Stripe\nVITE_STRIPE_PUBLIC_KEY=\"pk_test_your_key_here\"\nSTRIPE_SECRET_KEY=\"sk_test_your_key_here\"\n\n# PayPal\nVITE_PAYPAL_CLIENT_ID=\"your-paypal-client-id\"\nVITE_PAYPAL_ENV=\"sandbox\"\nPAYPAL_SECRET=\"your-paypal-secret\"\n\n# Fawry (Egyptian Payment Gateway)\nVITE_FAWRY_MERCHANT_CODE=\"your-fawry-merchant-code\"\nVITE_FAWRY_MERCHANT_REF=\"your-fawry-merchant-ref\"\n\n# ========================================\n# SMS Service Configuration\n# إعدادات خدمة الرسائل النصية\n# ========================================\n# Twilio\nVITE_TWILIO_ACCOUNT_SID=\"your-twilio-account-sid\"\nVITE_TWILIO_AUTH_TOKEN=\"your-twilio-auth-token\"\nVITE_TWILIO_PHONE_NUMBER=\"+1234567890\"\n\n# AWS SNS\nVITE_AWS_REGION=\"us-east-1\"\nVITE_AWS_ACCESS_KEY_ID=\"your-aws-access-key\"\nVITE_AWS_SECRET_ACCESS_KEY=\"your-aws-secret-key\"\n\n# ========================================\n# Cloud Storage Configuration\n# إعدادات التخزين السحابي\n# ========================================\n# AWS S3\nVITE_AWS_BUCKET=\"your-s3-bucket-name\"\n\n# Google Cloud Storage\nVITE_GCS_PROJECT_ID=\"your-gcs-project-id\"\nVITE_GCS_BUCKET=\"your-gcs-bucket-name\"\n\n# Azure Blob Storage\nVITE_AZURE_ACCOUNT_NAME=\"your-azure-account-name\"\nVITE_AZURE_ACCOUNT_KEY=\"your-azure-account-key\"\nVITE_AZURE_CONTAINER_NAME=\"your-container-name\"\n\n# ========================================\n# Maps and Location Services\n# خدمات الخرائط والمواقع\n# ========================================\nVITE_GOOGLE_MAPS_API_KEY=\"your-google-maps-api-key\"\nVITE_MAPBOX_ACCESS_TOKEN=\"your-mapbox-access-token\"\n\n# ========================================\n# Analytics Configuration\n# إعدادات التحليلات\n# ========================================\nVITE_GOOGLE_ANALYTICS_ID=\"G-XXXXXXXXXX\"\nVITE_MIXPANEL_TOKEN=\"your-mixpanel-token\"\nVITE_SEGMENT_WRITE_KEY=\"your-segment-write-key\"\n\n# ========================================\n# AI and Machine Learning Services\n# خدمات الذكاء الاصطناعي والتعلم الآلي\n# ========================================\nVITE_OPENAI_API_KEY=\"sk-your-openai-api-key\"\nVITE_VERTEX_AI_PROJECT_ID=\"your-vertex-ai-project-id\"\nVITE_VERTEX_AI_REGION=\"us-central1\"\nVITE_CLAUDE_API_KEY=\"your-claude-api-key\"\n\n# ========================================\n# Video Conference Services\n# خدمات المؤتمرات المرئية\n# ========================================\nVITE_ZOOM_CLIENT_ID=\"your-zoom-client-id\"\nVITE_ZOOM_CLIENT_SECRET=\"your-zoom-client-secret\"\nVITE_GOOGLE_MEET_API_KEY=\"your-google-meet-api-key\"\nVITE_JITSI_DOMAIN=\"meet.jit.si\"\n\n# ========================================\n# Electronic Signature Services\n# خدمات التوقيع الإلكتروني\n# ========================================\nVITE_DOCUSIGN_INTEGRATION_KEY=\"your-docusign-integration-key\"\nVITE_DOCUSIGN_USER_ID=\"your-docusign-user-id\"\nVITE_ADOBE_SIGN_CLIENT_ID=\"your-adobe-sign-client-id\"\nVITE_ADOBE_SIGN_CLIENT_SECRET=\"your-adobe-sign-client-secret\"\n\n# ========================================\n# Notification Services\n# خدمات الإشعارات\n# ========================================\nVITE_FCM_SERVER_KEY=\"your-fcm-server-key\"\nVITE_FCM_SENDER_ID=\"your-fcm-sender-id\"\nVITE_ONESIGNAL_APP_ID=\"your-onesignal-app-id\"\nVITE_ONESIGNAL_API_KEY=\"your-onesignal-api-key\"\n\n# ========================================\n# Document Processing Configuration\n# إعدادات معالجة المستندات\n# ========================================\nVITE_OCR_ENGINE=\"tesseract\"\nVITE_OCR_API_KEY=\"your-ocr-api-key\"\n\n# ========================================\n# Application Configuration\n# إعدادات التطبيق\n# ========================================\nNODE_ENV=\"development\"\nPORT=\"3000\"\nVITE_API_URL=\"http://localhost:3000/api\"\n\n# ========================================\n# Logging Configuration\n# إعدادات السجلات\n# ========================================\nLOG_LEVEL=\"info\"\nLOG_FORMAT=\"json\"\n\n# ========================================\n# Security Configuration\n# إعدادات الأمان\n# ========================================\nCORS_ORIGIN=\"http://localhost:3000\"\nRATE_LIMIT_WINDOW_MS=\"900000\"\nRATE_LIMIT_MAX_REQUESTS=\"100\"\n\n# ========================================\n# Cache Configuration\n# إعدادات التخزين المؤقت\n# ========================================\nREDIS_URL=\"redis://localhost:6379\"\nCACHE_TTL=\"3600\"\n\n# ========================================\n# Session Configuration\n# إعدادات الجلسة\n# ========================================\nSESSION_SECRET=\"your-session-secret-key-change-in-production\"\nSESSION_TIMEOUT=\"86400\"\n\n# ========================================\n# File Upload Configuration\n# إعدادات تحميل الملفات\n# ========================================\nMAX_FILE_SIZE=\"52428800\"\nALLOWED_FILE_TYPES=\"pdf,doc,docx,xls,xlsx,jpg,jpeg,png,txt\"\nUPLOAD_DIR=\"./uploads\"\n\n# ========================================\n# Backup Configuration\n# إعدادات النسخ الاحتياطية\n# ========================================\nBACKUP_ENABLED=\"true\"\nBACKUP_INTERVAL=\"86400\"\nBACKUP_RETENTION_DAYS=\"30\"\n\n# ========================================\n# Monitoring Configuration\n# إعدادات المراقبة\n# ========================================\nMONITORING_ENABLED=\"true\"\nMONITORING_INTERVAL=\"60000\"\n\n# ========================================\n# Testing Configuration\n# إعدادات الاختبار\n# ========================================\nTEST_DATABASE_URL=\"postgresql://user:password@localhost:5432/law_firm_test\"\nTEST_MODE=\"false\"\n\n# ========================================\n# Development Configuration\n# إعدادات التطوير\n# ========================================\nDEBUG=\"false\"\nVERBOSE=\"false\"\nHOT_RELOAD=\"true\"\n"
